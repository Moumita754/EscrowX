# Escrow contract id (C...) — the ONLY contract the frontend calls
VITE_CONTRACT_ID=

# PaymentVault contract id (C...) — display only; the Escrow contract calls it
VITE_VAULT_ID=

# Network: "testnet" | "mainnet" | "futurenet"
VITE_NETWORK=testnet

# Optional override for the Soroban RPC endpoint
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Asset token contract id used for escrow payments (defaults to native XLM SAC on testnet)
VITE_TOKEN_ID=
